<UserControl x:Class="DebugReplicator.View.VistaEditarArchivosCofig"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:DebugReplicator.View"
             xmlns:viewmodels="clr-namespace:DebugReplicator.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="{StaticResource color_fondo_body}">
        <StackPanel Width="800">
            <Label Content="Editar archivos de configuracion" HorizontalAlignment="Center" Margin="0,20,0,20" FontSize="20" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal">
                <Button Width="100" Height="30" HorizontalAlignment="Left" Margin="35,0,0,10" Command="{Binding VolverCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowBack" Width="15" Height="15" VerticalAlignment="Center"/>
                        <TextBlock Text="Atras"/>
                    </StackPanel>
                </Button>
                <!--
                <Button Width="100" Height="30" HorizontalAlignment="Left" Margin="30,0,0,10" Command="{Binding ContinuarCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Continuar"/>
                    </StackPanel>
                </Button>
                -->
                <Button Width="100" Height="30" HorizontalAlignment="Left" Margin="30,0,0,10" Command="{Binding ReplicarCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Replicar"/>
                    </StackPanel>
                </Button>

                <Border Margin="5,0,0,0">
                    <TextBlock Text="{Binding MensajeInfo}" Width="365"  TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <Border Margin="35 0 0 0" HorizontalAlignment="Left">
                    <ComboBox Width="200"  ItemsSource="{Binding ArchivosConfig}" SelectedItem="{Binding ArchivoConfigSeleccionado, Mode=TwoWay}" DisplayMemberPath="Name">
                        
                    </ComboBox>
                </Border>


                <ListBox ItemsSource="{Binding PropiedadesArchivoConfig, UpdateSourceTrigger=PropertyChanged}"
                            HorizontalContentAlignment="Stretch" Margin="0,0,0,0" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     />
                
               
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
