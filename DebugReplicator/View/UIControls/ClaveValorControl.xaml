<UserControl x:Class="DebugReplicator.View.UIControls.ClaveValorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DebugReplicator.View.UIControls"
             mc:Ignorable="d"
             Background="White"
             d:DesignHeight="20" d:DesignWidth="730">
    <Grid  Width="730">
        <StackPanel Orientation="Horizontal"  HorizontalAlignment="Left">            
            <Border>
                <TextBlock Text="{Binding Clave}" Width="380"/>
            </Border>
            <Border>
                <!--<TextBlock Text="{Binding DateModified}" HorizontalAlignment="Center"/>-->
                <TextBox Text="{Binding Valor, Mode=TwoWay }" HorizontalAlignment="Center" Width="350"/>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
